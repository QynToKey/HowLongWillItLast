<div>
  <%= form_with model: [@learning_theme, @tag], class: "container mt-4" do |f| %>
    <div class="mb-3">
      <%= f.label :name, class: "form-label" %><br>
      <%= f.text_field :name, class: "form-control" %>
    </div>

    <p class="text-muted small mt-3">※ 学習記録にタグを設定すると、タグごとに学習ログを管理できます</p>

    <div>
      <%= f.submit class: "btn btn-sm btn-primary" %>
      <%= link_to "戻る", return_path, class: "btn btn-sm btn-outline-secondary" %>
    </div>
  <% end %>
</div>
