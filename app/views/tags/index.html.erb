<div class="container mt-5">
  <h1 class="h4">タグ一覧</h1>

  <%= link_to 'タグを追加する', new_tag_path, class: "btn btn-sm btn-primary" %>
  <%= link_to '学習ログ', learning_records_path, class: "btn btn-sm btn-outline-primary" %>

  <table class="table table-hover">
    <thead>
      <tr>
        <th>タグ名</th>
      </tr>
    </thead>
    <tbody>
      <% @tags.each do |tag| %>
        <tr>
          <td><%= tag.name %></td>
          <td>
            <%= link_to '編集', edit_tag_path(tag), class: "btn btn-sm btn-outline-secondary" %>
            <%= link_to '削除', tag_path(tag), class: "btn btn-sm btn-outline-danger", data: { turbo_method: :delete, turbo_confirm: '本当に削除しますか？' } %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>

</div>
