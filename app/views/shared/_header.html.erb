<nav class="navbar navbar-expand-sm bg-body-tertiary">
  <div class="container">
  <%= link_to "How Long Will It Last", root_path, class: "nav-link text-muted" %>
    <div class="navbar-nav ms-auto">
      <% if logged_in? %>
        <%= link_to "マイページ", user_path(current_user), class: "nav-link" %>
        <%= link_to "ログアウト", logout_path, data: { turbo_method: :delete }, class: "nav-link" %>
      <% else %>
        <%= link_to "ログイン", login_path, class: "nav-link" %>
        <%= link_to "新規登録", new_user_path, class: "nav-link" %>
      <% end %>
    </div>
  </div>
</nav>

<div class="flash-messages">
  <% flash.each do |type, message| %>
    <div class="flash <%= type %>">
      <%= message %>
    </div>
  <% end %>
</div>
