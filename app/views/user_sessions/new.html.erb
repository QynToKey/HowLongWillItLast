<div class="container mt-5">
  <h1 class="h4">ログイン</h1>

  <%= form_with url: login_path, local: true, class: "container mt-4" do |f| %>
    <div class="mb-3">
      <%= label_tag :email, t('user_sessions.new.email') %>
      <%= text_field_tag :email, nil, autocomplete: "email", class: "form-control" %>
    </div>

    <div class="mb-3">
      <%= label_tag :password, t('user_sessions.new.password') %>
      <%= password_field_tag :password, nil, autocomplete: "current-password", class: "form-control" %>
    </div>

    <div>
      <%= submit_tag "ログイン", class: "btn btn-sm btn-primary" %>
    </div>
  <% end %>
</div>
