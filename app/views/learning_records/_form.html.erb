<%= form_with model: learning_record, class: "container mt-4" do |f| %>
  <%# 学習テーマIDをhidden_fieldで送信する（URLパラメータからではなく、フォームの一部として送信する） %>
  <%= hidden_field_tag :theme_id, @learning_theme&.id %>

  <div class="mb-3">
    <%= f.label :content, class: "form-label" %><br>
    <%= f.text_area :content, rows: 4, class: "form-control" %>
  </div>

  <div class="mb-3">
    <%= f.label :duration_minutes, class: "form-label" %><br>
    <%= f.number_field :duration_minutes, min: 0, class: "form-control", data: { stopwatch_target: "durationMinutes" }, placeholder: "※ 手入力も可能です（分単位）" %>
  </div>

  <div class="mb-3">
    <%= f.label :study_date, class: "form-label" %><br>
    <%= f.date_field :study_date, class: "form-control" %>
  </div>

  <div class="mb-3">
    <% if logged_in? %>
      <%= f.label :tag_ids, "タグ", class: "form-label" %><br>
      <% if @learning_theme.tags.empty? %>
        <p class="text-muted small">※ タグがありません。<%= link_to 'タグ管理', learning_theme_tags_path(@learning_theme) %>から追加してください。</p>
      <% else %>
        <% @learning_theme.tags.each do |tag| %>
          <%# タグがすでに付いていればチェック済みで表示し、チェックされたらそのIDを送信する %>
          <%= f.check_box :tag_ids, { multiple: true, checked: learning_record.tags.include?(tag) }, tag.id, false %>
          <%= tag.name %>
        <% end %>
      <% end %>
    <% else %>
      <p class="text-muted small mt-3">
      ※ 記録するには <%= link_to 'ユーザー登録', new_user_path %> /
      <%= link_to 'ログイン', login_path %> してください。
      </p>
    <% end %>
  </div>

  <div>
    <% if logged_in? %>
      <%= f.submit class: "btn btn-sm btn-primary" %>
      <%= link_to "タグ管理", learning_theme_tags_path(@learning_theme), class: "btn btn-sm btn-outline-primary" %>
      <%= link_to "学習ログ", learning_records_path(theme_id: @learning_theme.id), class: "btn btn-sm btn-outline-primary" %>
      <%= link_to 'マイページ', user_path(current_user), class: "btn btn-sm btn-outline-primary" %>
    <% end %>
  </div>

<% end %>
