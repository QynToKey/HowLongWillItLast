<%= form_with model: learning_record do |f| %>
  <div>
    <%= f.label :content %><br>
    <%= f.text_area :content, rows: 4 %>
  </div>

  <div>
    <%= f.label :duration_minutes %><br>
    <%= f.number_field :duration_minutes, min: 0, data: { stopwatch_target: "durationMinutes" } %>
  </div>

  <div>
    <%= f.label :study_date %><br>
    <%= f.date_field :study_date %>
  </div>

  <div>
    <% if logged_in? %>
      <%= f.label :tag_ids, "タグ" %><br>
      <% if current_user.tags.empty? %>
        <p>※ タグを先に<%= link_to 'タグ管理画面', tags_path %>から追加してください。</p>
      <% else %>
        <% current_user.tags.each do |tag| %>
          <%# タグがすでに付いていればチェック済みで表示し、チェックされたらそのIDを送信する %>
          <%= f.check_box :tag_ids, { multiple: true, checked: learning_record.tags.include?(tag) }, tag.id, false %>
          <%= tag.name %>
        <% end %>
      <% end %>
    <% else %>
      <p>※ 記録するにはユーザー登録 / ログインしてください。</p>
      <%= link_to 'ユーザー登録', new_user_path %> |
      <%= link_to 'ログイン', login_path %>
    <% end %>
  </div>

  <div>
    <% if logged_in? %>
      <%= f.submit %>
      <%= link_to "戻る", return_path %>
    <% end %>
  </div>

<% end %>
