<div class="container mt-5" style="max-width: 600px;">
  <h1 class="h4"><%= @learning_record.study_date.strftime('%Y/%m/%d') %> の学習記録</h1>

  <p>学習内容: <%= @learning_record.content %></p>
  <p>学習時間: <%= @learning_record.duration_minutes %> 分</p>

  <%= link_to '編集', edit_learning_record_path(@learning_record, theme_id: @learning_record.learning_theme.id), class: "btn btn-sm btn-primary" %>
  <%= link_to '学習ログ', learning_records_path(theme_id: @learning_record.learning_theme.id), class: "btn btn-sm btn-outline-primary" %>
  <%= link_to 'マイページ', user_path(current_user), class: "btn btn-sm btn-outline-primary" %>
</div>
