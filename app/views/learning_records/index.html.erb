<div class="container mt-5" style="max-width: 600px;">
  <% if params[:tag_id].present? %>
    <h1 class="h4">'<%= @current_tag.name %>' の学習ログ</h1>
  <% elsif params[:date].present? %>
    <h1 class="h4">'<%= Date.parse(params[:date]).strftime('%Y/%m/%d') %>' の学習ログ</h1>
  <% else %>
    <h1 class="h4">学習ログ</h1>
  <% end %>

  <%= link_to '今日の学習を記録する', new_learning_record_path(study_date: Date.current, theme_id: @learning_theme.id), class: "btn btn-sm btn-primary" %>
  <%= link_to 'タグ管理', learning_theme_tags_path(@learning_theme), class: "btn btn-sm btn-outline-primary" %>
  <%= link_to 'マイページ', user_path(current_user), class: "btn btn-sm btn-outline-primary" %>

  <table class="table table-hover">
    <thead>
      <tr>
        <th>学習日</th>
        <th>内容</th>
        <th>時間<span class="text-muted small">（分）</span></th>
        <th>タグ</th>
      </tr>
    </thead>
    <tbody>
      <% @learning_records.each do |record| %>
        <tr>
          <td><%= link_to record.study_date.strftime('%Y-%m-%d'), learning_records_path(date: record.study_date) %></td>
          <td><%= record.content %></td>
          <td><%= record.duration_minutes %></td>
          <td>
            <% record.tags.each do |tag| %>
              <%# タグ名をクリックすると、そのタグが付いている学習記録の一覧に遷移する %>
              <span><%= link_to tag.name, learning_records_path(tag_id: tag.id) %></span>
            <% end %>
          </td>
          <td>
            <%= link_to '編集', edit_learning_record_path(record), class: "btn btn-sm btn-outline-secondary" %>
            <%= link_to '削除', learning_record_path(record), class: "btn btn-sm btn-outline-danger", data: { turbo_method: :delete, turbo_confirm: '本当に削除しますか？' } %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>

  <div>
    <%# テーマごとの総学習時間を表示 %>
    <p class='small mt-3'>総学習時間（<%= @learning_theme.name %>）： <%= (@learning_theme.total_learning_minutes / 60.0).round(1) %> 時間</p>
  </div>

  <div>
    <%# タグで絞り込んでいる場合は全件表示へのリンクを表示する %>
    <% if params[:tag_id].present? %>
      <p class='text-muted small mt-3'>'<%= @current_tag.name %>' の学習時間累計： <%= (current_user.total_learning_minutes_by_tag(@current_tag) / 60.0).round(1) %> 時間</p>
      <%= link_to "全件表示へ戻る", learning_records_path, class: "btn btn-sm btn-outline-secondary" %>
    <%# 日付で絞り込んでいる場合は全件表示へのリンクを表示する %>
    <% elsif params[:date].present? %>
      <p class="text-muted small mt-3">'<%= Date.parse(params[:date]).strftime('%Y/%m/%d') %>' の学習時間累計： <%= (current_user.total_learning_minutes_by_date(Date.parse(params[:date])) / 60.0).round(1) %> 時間</p>
      <%= link_to "全件表示へ戻る", learning_records_path, class: "btn btn-sm btn-outline-secondary" %>
    <% end %>
  </div>

  <div>
    <% if current_user.learning_records.present? && current_user.tags.empty? %>
      <p class="text-muted small mt-3">※ タグがありません。（タグを設定すると、タグごとに学習ログを管理できます）</p>
      <%= link_to 'タグを追加する', new_learning_theme_tag_path(@learning_theme), class: "btn btn-sm btn-outline-primary" %>
    <% end %>
  </div>
</div>
