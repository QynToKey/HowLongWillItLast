<div class="container mt-5">
  <% if params[:tag_id].present? %>
    <h1 class="h4">'<%= @current_tag.name %>' の学習ログ</h1>
  <% elsif params[:date].present? %>
    <h1 class="h4">'<%= Date.parse(params[:date]).strftime('%Y/%m/%d') %>' の学習ログ</h1>
  <% else %>
    <h1 class="h4">学習ログ</h1>
  <% end %>

  <%= link_to '記録を追加する', new_learning_record_path, class: "btn btn-sm btn-primary" %>

  <table class="table table-hover">
    <thead>
      <tr>
        <th>学習日</th>
        <th>内容</th>
        <th>時間<span class="text-muted small">（分）</span></th>
        <th>タグ</th>
      </tr>
    </thead>
    <tbody>
      <% @learning_records.each do |record| %>
        <tr>
          <td><%= link_to record.study_date.strftime('%Y-%m-%d'), learning_records_path(date: record.study_date) %></td>
          <td><%= record.content %></td>
          <td><%= record.duration_minutes %></td>
          <td>
            <% record.tags.each do |tag| %>
              <%# タグ名をクリックすると、そのタグが付いている学習記録の一覧に遷移する %>
              <span><%= link_to tag.name, learning_records_path(tag_id: tag.id) %></span>
            <% end %>
          </td>
          <td>
            <%= link_to '編集', edit_learning_record_path(record), class: "btn btn-sm btn-outline-secondary" %>
            <%= link_to '削除', learning_record_path(record), class: "btn btn-sm btn-outline-danger", data: { turbo_method: :delete, turbo_confirm: '本当に削除しますか？' } %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>

  <%# タグで絞り込んでいる場合は全件表示へのリンクを表示する %>
  <% if params[:tag_id].present? %>
    <p>'<%= @current_tag.name %>' の学習時間累計： <%= (current_user.total_learning_minutes_by_tag(@current_tag) / 60.0).round(1) %> 時間</p>
    <%= link_to "全件表示へ戻る", learning_records_path, class: "btn btn-sm btn-outline-secondary" %>
  <%# 日付で絞り込んでいる場合は全件表示へのリンクを表示する %>
  <% elsif params[:date].present? %>
    <p>'<%= Date.parse(params[:date]).strftime('%Y/%m/%d') %>' の学習時間累計： <%= (current_user.total_learning_minutes_by_date(Date.parse(params[:date])) / 60.0).round(1) %> 時間</p>
    <%= link_to "全件表示へ戻る", learning_records_path, class: "btn btn-sm btn-outline-secondary" %>
  <% end %>

  <% if current_user.learning_records.present? && current_user.tags.empty? %>
    <p>タグがありません。タグを追加して学習ログを管理しましょう！</p>
    <%= link_to 'タグを追加する', new_tag_path, class: "btn btn-sm btn-outline-primary" %>
  <% end %>
</div>
