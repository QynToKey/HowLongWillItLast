<h1>学習ログ</h1>

<%= link_to '記録を追加する', new_learning_record_path %>

<table>
  <thead>
    <tr>
      <th>学習日</th>
      <th>内容</th>
      <th>時間（分）</th>
    </tr>
  </thead>
  <tbody>
    <% @learning_records.each do |record| %>
      <tr>
        <td><%= record.study_date.strftime('%Y-%m-%d') %></td>
        <td><%= record.content %></td>
        <td><%= record.duration_minutes %></td>
        <td>
          <% record.tags.each do |tag| %>
            <%# タグ名をクリックすると、そのタグが付いている学習記録の一覧に遷移する %>
            <span><%= link_to tag.name, learning_records_path(tag_id: tag.id) %></span>
          <% end %>
        </td>
        <td>
          <%= link_to '編集', edit_learning_record_path(record) %>
          <%= link_to '削除', learning_record_path(record), data: { turbo_method: :delete, turbo_confirm: '本当に削除しますか？' } %>
        </td>
      </tr>
    <% end %>
  </tbody>
</table>

<%# タグで絞り込んでいる場合は全件表示へのリンクを表示する %>
<% if params[:tag_id].present? %>
  <p>このタグのついた学習ログの累計: <%= (current_user.total_learning_minutes_by_tag(@current_tag) / 60.0).round(1) %> 時間</p>
  <%= link_to "全件表示へ戻る", learning_records_path %>
<% end %>
